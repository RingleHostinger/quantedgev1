# ─── Supabase / nubase (client-side, public) ──────────────────────────────────
NEXT_PUBLIC_DATABASE_URL=
NEXT_PUBLIC_DATABASE_PUBLISHABLE_KEY=

# ─── Supabase / nubase (server-side, secret) ──────────────────────────────────
DATABASE_URL=
DATABASE_SERVICE_ROLE_KEY=

# ─── Odds API ─────────────────────────────────────────────────────────────────
# Get your key at https://the-odds-api.com
ODDS_API_KEY=

# ─── Cron Security ────────────────────────────────────────────────────────────
# Random secret string shared between Vercel and cron routes.
# Vercel sends: Authorization: Bearer <CRON_SECRET>
# Generate with: openssl rand -hex 32
CRON_SECRET=

# ─── JWT Auth ─────────────────────────────────────────────────────────────────
# Used to sign session tokens. Must be at least 32 characters.
# Generate with: openssl rand -hex 32
JWT_SECRET=

# ─── Stripe (optional — only if payment features are used) ────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PREMIUM_PRICE_ID=
NEXT_PUBLIC_STRIPE_URL=

# ─── App URL ──────────────────────────────────────────────────────────────────
# Your production URL (e.g. https://your-app.vercel.app)
NEXT_PUBLIC_APP_URL=
